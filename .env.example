# === REQUIRED ===
TELEGRAM_BOT_TOKEN=       # From @BotFather
LLM_API_KEY=              # OpenRouter API key
LLM_BASE_URL=https://openrouter.ai/api/v1

# === OPTIONAL: Database (bot works without — no persistence) ===
SUPABASE_URL=             # Supabase project URL
SUPABASE_SERVICE_KEY=     # Supabase service role key

# === OPTIONAL: Memory (bot works without — no long-term memory) ===
MEM0_API_KEY=             # mem0 API key

# === OPTIONAL: Images (bot works without — text-only mode) ===
IMAGE_API_KEY=            # OpenRouter key (can be same as LLM_API_KEY)
IMAGE_BASE_URL=https://openrouter.ai/api/v1
IMAGE_MODEL=bytedance/seedream-4.5

# === OPTIONAL: Observability ===
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENABLED=true     # Set to false to disable

# === OPTIONAL: Redis (proactive scheduler uses in-memory store without) ===
REDIS_URL=redis://localhost:6379
